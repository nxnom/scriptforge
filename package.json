{
  "name": "scriptforge",
  "version": "0.1.2",
  "description": "A local app store for utilities forged on demand with Codex.",
  "keywords": [
    "codex",
    "local-first",
    "productivity",
    "utilities"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nxnom/scriptforge.git"
  },
  "homepage": "https://github.com/nxnom/scriptforge#readme",
  "bugs": {
    "url": "https://github.com/nxnom/scriptforge/issues"
  },
  "type": "module",
  "bin": {
    "scriptforge": "dist/cli.js"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/clean-dist.mjs && pnpm build:web && pnpm build:server && pnpm build:tools",
    "build:server": "tsup",
    "build:tools": "node scripts/copy-tools.mjs",
    "build:web": "vite build",
    "dev": "concurrently -k -n server,web -c cyan,magenta \"pnpm dev:server\" \"pnpm dev:web\"",
    "dev:server": "tsx watch src/cli.ts --no-open",
    "dev:web": "vite --host 127.0.0.1 --open",
    "check": "biome check .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "prepack": "pnpm build",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@geckoui/geckoui": "^1.6.3",
    "@hono/node-server": "^2.0.10",
    "@hookform/resolvers": "^5.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@spoosh/core": "^0.18.3",
    "@spoosh/hono": "^0.6.2",
    "@spoosh/plugin-cache": "^0.7.0",
    "@spoosh/plugin-deduplication": "^0.4.0",
    "@spoosh/plugin-invalidation": "^0.11.0",
    "@spoosh/plugin-optimistic": "^0.10.0",
    "@spoosh/react": "^0.15.4",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "hono": "^4.12.30",
    "lucide-react": "^1.25.0",
    "mermaid": "^11.16.0",
    "node-pty": "1.2.0-beta.12",
    "open": "^10.2.0",
    "pdf-lib": "1.17.1",
    "pdfjs-dist": "5.4.624",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.66.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.35.3",
    "ws": "^8.21.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@tailwindcss/vite": "^4.1.0",
    "@testing-library/jest-dom": "^6.9.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.0",
    "jsdom": "^27.2.0",
    "tailwindcss": "^4.1.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "vite": "^7.2.0",
    "vitest": "^4.0.0"
  },
  "packageManager": "pnpm@10.30.3"
}
